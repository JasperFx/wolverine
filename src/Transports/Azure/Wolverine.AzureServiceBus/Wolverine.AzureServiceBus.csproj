<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>WolverineFx.AzureServiceBus</PackageId>
        <Description>Azure Service Bus transport for Wolverine applications</Description>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Wolverine\Wolverine.csproj"/>
        <!--
          UseNServiceBusInterop() / UseMassTransitInterop() pin a NewtonsoftSerializer
          for wire-format compatibility with NSB / MT producers. Newtonsoft moved out
          of WolverineFx core in 6.0; the transport carries the dependency so users
          opting into the interop paths don't need the extra install by hand.
        -->
        <ProjectReference Include="..\..\..\Extensions\Wolverine.Newtonsoft\Wolverine.Newtonsoft.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Azure.Identity" />
        <PackageReference Include="Azure.Messaging.ServiceBus" />

    </ItemGroup>

</Project>
