<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>WolverineFx.AmazonSqs</PackageId>
        <Description>Amazon SQS transport for Wolverine applications</Description>
        <!--
          AOT-compatible (#2746). Three IL warning sites resolved:
          - RawJsonSqsEnvelopeMapper.BuildMessageBody / ReadEnvelopeData:
            leaf-suppressed (runtime-resolved user message types; AOT
            consumers supply a JsonSerializerContext-backed mapper)
          - SnsTopicEnvelopeMapper.ReadMessageBody: refactored to use
            source-generated SnsMessageMetadataJsonContext (chunk N pattern)
        -->
        <IsAotCompatible>true</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Wolverine\Wolverine.csproj"/>
        <!--
          UseNServiceBusInterop() pins a NewtonsoftSerializer for wire-format
          compatibility with NSB producers. Newtonsoft moved out of WolverineFx
          core in 6.0; the transport carries the dependency so users opting
          into the NSB-interop path don't need the extra install by hand.
        -->
        <ProjectReference Include="..\..\..\Extensions\Wolverine.Newtonsoft\Wolverine.Newtonsoft.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="AWSSDK.SQS" />
    </ItemGroup>
</Project>

